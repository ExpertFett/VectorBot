# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# Discord bot token (Developer Portal > your app > Bot > Reset Token)
DISCORD_TOKEN=

# Application (Client) ID (Developer Portal > your app > General Information > Application ID)
DISCORD_CLIENT_ID=

# Your server (guild) ID. Enable Developer Mode in Discord, right-click the server > Copy Server ID.
# With this set, slash commands register instantly to this one server (good for a single-community bot).
# Leave blank to register globally (can take up to ~1 hour to propagate).
DISCORD_GUILD_ID=

# Prefix for custom (Mee6-style) text commands, e.g. !rules
COMMAND_PREFIX=!

# Where the SQLite database file lives.
# Local default below works out of the box. On Railway, attach a Volume mounted at /data
# and set DB_PATH=/data/bot.db so data survives restarts/redeploys.
DB_PATH=./data/bot.db

# ---- Web dashboard ----

# OAuth2 Client Secret (Developer Portal > your app > OAuth2 > Reset Secret).
DISCORD_CLIENT_SECRET=

# Secret used to sign dashboard session cookies. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Public base URL of the dashboard. Locally this is http://localhost:3000.
# On Railway, set it to your service's public URL, e.g. https://vectorbot.up.railway.app
# The OAuth2 redirect URL is BASE_URL + /auth/callback — add that EXACT URL in the
# Developer Portal under OAuth2 > Redirects.
BASE_URL=http://localhost:3000

# Port the dashboard listens on. Railway sets this automatically; 3000 for local dev.
PORT=3000
